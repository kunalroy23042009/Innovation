# AI Setup Agent — Environment Variables
# Copy this file to .env and fill in your values.

# ── Required: Groq API key (primary LLM) ──────────────────────────────────────
# Get yours free at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: Ollama host (default: local) ────────────────────────────────────
# Only change this if Ollama is running on a remote machine.
# OLLAMA_HOST=http://localhost:11434

# ── Optional: Enable verbose debug logging ────────────────────────────────────
# AI_AGENT_DEBUG=true
